{
  "testEnvironment": "node",
  "testMatch": [
    "**/tests/**/*.test.js",
    "**/?(*.)+(spec|test).js"
  ],
  "collectCoverageFrom": [
    "app.js",
    "!**/node_modules/**",
    "!**/tests/**"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    }
  },
  "testTimeout": 10000,
  "collectCoverage": false,
  "coverageReporters": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "verbose": true
}
