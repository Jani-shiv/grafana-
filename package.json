{
  "name": "stellarmind-observability-stack",
  "version": "1.0.0",
  "description": "Production-oriented Prometheus and Grafana monitoring stack with CI/CD automation.",
  "main": "app.js",
  "author": "Stellarmind Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint app.js --max-warnings 0",
    "lint:fix": "eslint app.js --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "validate": "npm run lint && npm run test && npm run format:check",
    "docker:build": "docker build -t stellarmind:latest .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/data:/usr/src/app/data stellarmind:latest",
    "prepush": "npm run validate"
  },
  "dependencies": {
    "express": "^4.21.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^2.1.1",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "snyk": "^1.1279.0"
  },
  "optionalDependencies": {
    "snyk": "*"
  },
  "keywords": [
    "prometheus",
    "grafana",
    "observability",
    "monitoring",
    "metrics",
    "docker",
    "azure",
    "cicd"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jani-shiv/grafana-.git"
  },
  "bugs": {
    "url": "https://github.com/Jani-shiv/grafana-/issues"
  },
  "homepage": "https://github.com/Jani-shiv/grafana-#readme"
}
